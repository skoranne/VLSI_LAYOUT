# Control file for MAGPARSER
program square
systeminfo
decl design d1 = INV.mag
decl output o1 = foo.mag
decl output o2 = bar.mag
decl memory f1 = nothing
info
exec run f1:diff = d1:pdiff + d1:ndiff
exec run o1:gate = d1:poly * f1:diff
exec run o2:gate = f1:diff * d1:poly
exec run o1:sd =  f1:diff - d1:poly
exec run o2:sd = f1:diff ~ d1:poly
flush
end 